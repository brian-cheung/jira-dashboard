{
  "name": "jira-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && node index.js",
    "client": "cd client && npx vite --port 5173",
    "build": "cd client && npx vite build",
    "start": "cd server && node index.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
